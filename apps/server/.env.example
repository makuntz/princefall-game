# Banco
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/princefall"

# JWT (use um segredo forte em produção)
JWT_SECRET="change-me"

# URL do frontend (links de confirmação de e-mail)
WEB_ORIGIN="http://localhost:3000"

# E-mail transacional
# Sem SMTP, NENHUM e-mail é enviado — só o link no terminal do servidor e (em dev) na faixa azul após cadastro.
#
# Teste local com Mailpit (docker): docker run -p 8025:8025 -p 1025:1025 axllent/mailpit
# Depois use:
# SMTP_HOST="localhost"
# SMTP_PORT="1025"
# SMTP_SECURE="false"
# SMTP_FROM="Dev <dev@localhost>"
# (sem SMTP_USER / SMTP_PASS em Mailpit)
#
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Queda da coroa <noreply@example.com>"
