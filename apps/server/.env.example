# Banco
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/princefall"

# JWT (use um segredo forte em produção)
JWT_SECRET="change-me"

# URL do frontend (links de confirmação de e-mail)
WEB_ORIGIN="http://localhost:3000"

# E-mail transacional via API Brevo (HTTPS — compatível com Railway sem porta SMTP)
# Crie a chave em: https://app.brevo.com/settings/keys/api
# Remetente deve estar verificado na Brevo.
BREVO_API_KEY=""
EMAIL_FROM="Queda da coroa <noreply@seudominio.com>"

# Sem BREVO_API_KEY, nenhum e-mail é enviado — o link de verificação só aparece no log do servidor
# e (em NODE_ENV !== production) na resposta JSON como devVerificationUrl / faixa na UI.
